# ========================
# Jóvenes al Ruedo — Variables de Entorno (Plantilla)
# ========================
# ¿Qué? Plantilla con TODAS las variables de entorno que necesita el backend.
# ¿Para qué? Guiar a cada desarrollador sobre qué variables configurar sin exponer datos reales.
# ¿Impacto? Sin este archivo, los nuevos desarrolladores no sabrían qué variables necesitan,
#           causando errores al iniciar la aplicación.
#
# INSTRUCCIONES:
# 1. Copiar este archivo: cp .env.example .env
# 2. Editar .env con valores reales para tu entorno local
# 3. NUNCA versionar el archivo .env en git

# ────────────────────────────
# 🗄️ Base de datos
# ────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
#
# ⚠️  IMPORTANTE según el entorno:
#   Desarrollo LOCAL (sin Docker):  host = localhost
#   Desarrollo con Docker Compose:  host = db  (nombre del servicio en compose)
DATABASE_URL=postgresql://jar_user:jar_password@localhost:5432/jovenes_al_ruedo

# ────────────────────────────
# 🔐 JWT y Seguridad
# ────────────────────────────
# Clave secreta para firmar tokens JWT — CAMBIAR en producción
# Generar una clave segura: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Algoritmo de firma JWT
ALGORITHM=HS256

# Duración del access token en minutos (15 min = sesión corta por seguridad)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Duración del refresh token en días (7 días = una semana)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ────────────────────────────
# 📧 Email (para recuperación de contraseña)
# ────────────────────────────
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@jovenes-al-ruedo.com
MAIL_PASSWORD=your-mail-password
MAIL_FROM=noreply@jovenes-al-ruedo.com
MAIL_FROM_NAME=Jóvenes al Ruedo

# ────────────────────────────
# 🌐 URLs
# ────────────────────────────
# URL del frontend (para enlaces en emails de recuperación y CORS)
FRONTEND_URL=http://localhost:5173
